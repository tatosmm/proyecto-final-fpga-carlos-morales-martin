library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity ADC_System_Integrated_tb is
end ADC_System_Integrated_tb;

architecture Behavioral of ADC_System_Integrated_tb is

    -- Componentes principales
    component ADC_CONTROLLER is
        port( D1_in   : in STD_LOGIC;
              START   : in STD_LOGIC;
              rst     : in STD_LOGIC;
              clk_in  : in STD_LOGIC;
              DRDY    : out STD_LOGIC;
              D1_out  : out STD_LOGIC_VECTOR (11 downto 0);
              clk_out : out STD_LOGIC;
              CS      : out STD_LOGIC);
    end component;

    component AddrCtrl is
        generic ( ADDR_WIDTH : integer );
        port ( clk    : in  std_logic;
               rst    : in  std_logic;
               DONE   : in  std_logic;
               addr_rd: out std_logic_vector(ADDR_WIDTH-1 downto 0);
               START  : out std_logic );
    end component;

    component Memoria_RAM is
        Generic ( d_width : integer; addr_width : integer );
        Port ( clk      : in STD_LOGIC;
               wr_en    : in STD_LOGIC;
               addr_rd  : in STD_LOGIC_VECTOR (addr_width-1 downto 0);
               addr_wr  : in STD_LOGIC_VECTOR (addr_width-1 downto 0);
               data_in  : in STD_LOGIC_VECTOR (d_width-1 downto 0);
               data_out : out STD_LOGIC_VECTOR (d_width-1 downto 0));
    end component;

    -- Constantes
    constant ADDR_WIDTH : integer := 14;
    constant DATA_WIDTH : integer := 12;

    -- Señales de interconexión
    signal clk_100M     : std_logic := '0';
    signal rst          : std_logic := '0';
    signal adc_D1_in    : std_logic := '0';
    signal sig_start    : std_logic;
    signal sig_start_tb : std_logic := '0'; -- Para el arranque inicial
    signal sig_start_combined : std_logic;
    
    signal sig_drdy     : std_logic;
    signal sig_d1_bus   : std_logic_vector(11 downto 0);
    signal sig_sclk     : std_logic;
    signal sig_cs       : std_logic;
    
    signal sig_addr_wr  : std_logic_vector(ADDR_WIDTH-1 downto 0);
    signal ram_data_out : std_logic_vector(DATA_WIDTH-1 downto 0);

begin

    -- Lógica de arranque: Combinamos el START del AddrCtrl con un pulso manual del TB
    sig_start_combined <= sig_start or sig_start_tb;

    -- 1. Instancia del Controlador ADC Completo
    U_ADC: ADC_CONTROLLER 
        port map (
            D1_in   => adc_D1_in,
            START   => sig_start_combined,
            rst     => rst,
            clk_in  => clk_100M,
            DRDY    => sig_drdy,
            D1_out  => sig_d1_bus,
            clk_out => sig_sclk,
            CS      => sig_cs
        );

    -- 2. Instancia del Control de Direcciones
    U_AddrCtrl: AddrCtrl 
        generic map ( ADDR_WIDTH => ADDR_WIDTH )
        port map (
            clk     => clk_100M,
            rst     => rst,
            DONE    => sig_drdy, -- Incrementa cuando el ADC termina
            addr_rd => sig_addr_wr,
            START   => sig_start  -- Genera el siguiente START automáticamente
        );

    -- 3. Instancia de la Memoria RAM
    U_RAM: Memoria_RAM 
        generic map ( d_width => DATA_WIDTH, addr_width => ADDR_WIDTH )
        port map (
            clk      => clk_100M,
            wr_en    => sig_drdy,
            addr_rd  => (others => '0'), -- No estamos leyendo en este TB
            addr_wr  => sig_addr_wr,
            data_in  => sig_d1_bus,
            data_out => ram_data_out
        );

    -- Generador de Reloj (100 MHz)
    clk_process : process begin
        clk_100M <= '0'; wait for 5 ns;
        clk_100M <= '1'; wait for 5 ns;
    end process;

    -- PROCESO DE ESTÍMULOS (SOLUCIÓN AL BLOQUEO)
    stim_proc: process begin
        -- 1. Reset inicial
        rst <= '0';
        wait for 100 ns;
        rst <= '1';
        wait for 100 ns;

        -- 2. ARRANQUE INICIAL (Kickstart)
        -- Pulsamos START manualmente una vez para sacar a la FSM de HOLD
        sig_start_tb <= '1';


        
        report "Simulación finalizada. Revisa la RAM para ver los datos capturados.";
        wait;
    end process;

    -- GENERADOR DE DATOS SERIE (Simula un Pmod AD1 enviando una rampa)
    -- Esto permite observar el movimiento real de los bits
    serial_data_gen: process
        variable v_data : unsigned(11 downto 0) := x"A00"; -- Empezamos en A00
    begin
        wait until sig_cs = '0'; -- El ADC externo empieza cuando CS cae
        
        -- El Pmod AD1 envía 4 ceros iniciales y luego los 12 bits de datos
        -- Sincronizado con el flanco de bajada de SCLK
        for i in 1 to 4 loop -- 4 ceros de control
            adc_D1_in <= '0';
            wait until falling_edge(sig_sclk);
        end loop;

        for i in 11 downto 0 loop -- 12 bits de datos (MSB primero)
            adc_D1_in <= v_data(i);
            wait until falling_edge(sig_sclk);
        end loop;

        v_data := v_data + 1; -- Incrementamos para la siguiente captura (Rampa)
        
        wait until sig_cs = '1'; -- Esperar a que termine la trama
    end process;
    
end Behavioral;
