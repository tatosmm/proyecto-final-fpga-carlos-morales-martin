library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity DAC_System_Integrated_tb is
end DAC_System_Integrated_tb;

architecture Behavioral of DAC_System_Integrated_tb is

    -- Componentes (Mantenemos tus declaraciones originales)
    component Prescaler is
        generic ( N_BITS : integer; VAL_DIV : integer );
        Port ( rst : in STD_LOGIC; clk_in : in STD_LOGIC; clk_out : out STD_LOGIC);
    end component;

    component Memoria_RAM is
        Generic ( d_width : integer; addr_width : integer );
        Port ( clk, wr_en : in STD_LOGIC;
               addr_rd, addr_wr : in STD_LOGIC_VECTOR (addr_width-1 downto 0);
               data_in : in STD_LOGIC_VECTOR (d_width-1 downto 0);
               data_out : out STD_LOGIC_VECTOR (d_width-1 downto 0));
    end component;

    component AddrCtrl is
        generic ( ADDR_WIDTH : integer );
        port ( clk, rst, DONE : in std_logic;
               addr_rd : out std_logic_vector(ADDR_WIDTH-1 downto 0);
               START : out std_logic );
    end component;

    component FSM is
        generic ( SHIFT_ANCHO : integer );
        Port ( clkDiv, START, rst : in STD_LOGIC;
               Sft_Counter : in std_logic_vector(SHIFT_ANCHO-1 downto 0);
               en_Sft, DONE, nSYNC, LoadData : out STD_LOGIC );
    end component;

    component Shift_Register is
        Generic ( SHIFT_ANCHO, N_Bits_D, N_BITS_SPI : integer );
        Port ( clk : in STD_LOGIC;
               in_D1: in STD_LOGIC_VECTOR (N_Bits_D-1 downto 0);
               LoadData, en_Sft : in STD_LOGIC;
               out_D1: out STD_LOGIC;
               Sft_Counter : out STD_LOGIC_VECTOR (SHIFT_ANCHO-1 downto 0));
    end component;

    -- Constantes
    constant SHIFT_ANCHO : integer := 4;
    constant N_Bits_D    : integer := 12;
    constant N_BITS_SPI  : integer := 16;
    constant addr_width  : integer := 14;
    constant VAL_DIV     : integer := 8; 
    constant N_BITS_PSC  : integer := 4;

    -- Señales
    signal clk_200M : std_logic := '0';
    signal rst      : std_logic := '0';
    signal clk_25M  : std_logic;
    
    signal ram_wr_en    : std_logic := '0';
    signal ram_addr_rd  : std_logic_vector(addr_width-1 downto 0);
    signal ram_addr_wr  : std_logic_vector(addr_width-1 downto 0) := (others => '0');
    signal ram_data_in  : std_logic_vector(N_Bits_D-1 downto 0) := (others => '0');
    signal ram_data_out : std_logic_vector(N_Bits_D-1 downto 0);

    signal sig_start, sig_done : std_logic;
    signal sig_en_sft, sig_load : std_logic;
    signal sig_sft_cnt : std_logic_vector(SHIFT_ANCHO-1 downto 0);
    signal dac_nSYNC, dac_D1 : std_logic;

begin

    -- 1. Prescaler (Reloj SPI)
    U_Prescaler: Prescaler 
        generic map ( N_BITS => N_BITS_PSC, VAL_DIV => VAL_DIV )
        port map ( rst => rst, clk_in => clk_200M, clk_out => clk_25M );

    -- 2. Memoria RAM (Reloj de sistema para escritura rápida)
    U_RAM: Memoria_RAM 
        generic map ( d_width => N_Bits_D, addr_width => addr_width )
        port map ( clk => clk_200M, wr_en => ram_wr_en, addr_rd => ram_addr_rd, 
                   addr_wr => ram_addr_wr, data_in => ram_data_in, data_out => ram_data_out );

    -- 3. AddrCtrl (¡CAMBIO CLAVE!: Ahora usa clk_25M)
    -- Al usar el reloj lento, el pulso START durará 40ns, lo justo para la FSM.
    U_AddrCtrl: AddrCtrl 
        generic map ( ADDR_WIDTH => addr_width )
        port map ( clk => clk_25M, rst => rst, DONE => sig_done, 
                   addr_rd => ram_addr_rd, START => sig_start );

    -- 4. FSM
    U_FSM: FSM 
        generic map ( SHIFT_ANCHO => SHIFT_ANCHO )
        port map ( clkDiv => clk_25M, START => sig_start, rst => rst, 
                   Sft_Counter => sig_sft_cnt, en_Sft => sig_en_sft, 
                   DONE => sig_done, nSYNC => dac_nSYNC, LoadData => sig_load );

    -- 5. Shift Register
    U_ShiftReg: Shift_Register 
        generic map ( SHIFT_ANCHO => SHIFT_ANCHO, N_Bits_D => N_Bits_D, N_BITS_SPI => N_BITS_SPI )
        port map ( clk => clk_25M, in_D1 => ram_data_out, 
                   LoadData => sig_load, en_Sft => sig_en_sft, 
                   out_D1 => dac_D1, Sft_Counter => sig_sft_cnt );

    -- Generación de Reloj Principal
    process begin
        clk_200M <= '0'; wait for 2.5 ns;
        clk_200M <= '1'; wait for 2.5 ns;
    end process;

    -- Estímulos
    process begin
        -- Reset inicial
        rst <= '0';
        wait for 100 ns;
        rst <= '1';
        
        -- Precarga de datos en RAM (Usamos clk_200M para la escritura)
        ram_wr_en <= '1';
        ram_addr_wr <= (others => '0');
        ram_data_in <= x"A5C"; -- Dato 1
        wait for 5 ns;
        ram_addr_wr <= std_logic_vector(to_unsigned(1, addr_width));
        ram_data_in <= x"FFF"; -- Dato 2
        wait for 5 ns;
        ram_wr_en <= '0';

        -- Observar el funcionamiento durante varios ciclos de transmisión
        -- Cada transmisión de 16 bits a 25MHz tarda 640ns + estados extra.
        wait for 50 us; 
        
        report "Simulación terminada. Revisa dac_D1 para ver el dato serie.";
        wait;
    end process;

end Behavioral;
